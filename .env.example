# Nginx Proxy Manager - environment variables
# Copy to .env or paste into your stack manager environment.

# --- Container names ---
NPM_CONTAINER_NAME=nginx-proxy-manager
DB_CONTAINER_NAME=nginx-proxy-manager-db

# --- Published ports ---
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81

# --- Runtime ---
DISABLE_IPV6=true

# --- Database ---
MYSQL_DATABASE=npm
MYSQL_USER=npm
MYSQL_ROOT_PASSWORD=change_me_generate_random_root_password
MYSQL_PASSWORD=change_me_generate_random_db_password
